---
import { Image } from 'astro:assets';
import Layout from '../layouts/Layout.astro';
import { SITE } from '../site.config';

import '../styles/format.css';
import '../styles/merch.css';

import merch1 from '../assets/images/rrmerch1.png';
import merch2 from '../assets/images/rrmerch2.png';
import merch3 from '../assets/images/rrmerch3.png';
import merch4 from '../assets/images/rrmerch4.png';
import merch5 from '../assets/images/rrmerch5.png';
import merch6 from '../assets/images/rrmerch6.png';
import merch7 from '../assets/images/rrmerch7.png';
import merch8 from '../assets/images/rrmerch8.png';

const merchSlides = [
  { src: merch1, href: 'https://arma.gg/collections/rocket-rivals/1', alt: 'Rocket Rivals x Arma Merch 1' },
  { src: merch2, href: 'https://arma.gg/collections/rocket-rivals/2', alt: 'Rocket Rivals x Arma Merch 2' },
  { src: merch3, href: 'https://arma.gg/collections/rocket-rivals/3', alt: 'Rocket Rivals x Arma Merch 3' },
  { src: merch4, href: 'https://arma.gg/collections/rocket-rivals/4', alt: 'Rocket Rivals x Arma Merch 4' },
  { src: merch5, href: 'https://arma.gg/collections/rocket-rivals/5', alt: 'Rocket Rivals x Arma Merch 5' },
  { src: merch6, href: 'https://arma.gg/collections/rocket-rivals/6', alt: 'Rocket Rivals x Arma Merch 6' },
  { src: merch7, href: 'https://arma.gg/collections/rocket-rivals/7', alt: 'Rocket Rivals x Arma Merch 7' },
  { src: merch8, href: 'https://arma.gg/collections/rocket-rivals/8', alt: 'Rocket Rivals x Arma Merch 8' },
];
---
<Layout
  title="Competitive Rocket League Community, Leagues, and More!"
  description="Rocket Rivals is a competitive Rocket League community with structured 3v3 leagues, weekend match nights, and a home for players of every rank."
>
  <div>
    <h1>Welcome to the official Rocket Rivals website!</h1>
    <hr />
    <p>Rocket Rivals is a competitive Rocket League community built for players who want structured leagues, fair competition, and a place to grow.&nbsp;</p>
    <p>Whether you're here to follow the latest seasons, track team and player stats, or join the action yourself, Rocket Rivals brings everything together in one hub: competition, community, and rivalries that matter. &nbsp;</p>
    <p>Join our <a href={SITE.discordInvite}>Discord</a>, follow our <a href={SITE.twitchUrl}>Twitch</a>, and join one of our <a href="/divisions">division servers</a>!</p>
  </div>

  <div class="rr-spacer rr-spacer--sm"></div>

  <div class="rr-format">
    <div class="rr-format__intro">
      <p><span class="rr-format__label">How It Works</span></p>
      <h2 class="rr-format__title">League Format</h2>
      <p class="rr-format__body">The league operates on a weekend-based schedule. Teams compete in a 3v3 format, twice a week, with official match days scheduled for Saturday or Sunday evenings.</p>
    </div>
    <div class="rr-format__cards">
      <div class="rr-format__card" data-accent="purple"><span class="rr-format__stat">3v3</span> <span class="rr-format__name">Team Format</span></div>
      <div class="rr-format__card" data-accent="orange"><span class="rr-format__stat">2&times;</span> <span class="rr-format__name">Per Week</span></div>
      <div class="rr-format__card" data-accent="pink"><span class="rr-format__stat">Sat / Sun</span> <span class="rr-format__name">Match Nights</span></div>
    </div>
  </div>

  <div class="rr-spacer rr-spacer--sm"></div>

  <div class="rr-merch">
    <header class="rr-merch__header">
      <p><span class="rr-merch__eyebrow">Merch</span></p>
      <h2 class="rr-merch__headline">Official Rocket Rivals merchandise is here! Thank you for the support!</h2>
      <p class="rr-merch__sub">We&rsquo;ve teamed up with Arma to bring you exclusive branded gear.</p>
    </header>

    <div class="rr-carousel">
      <div class="rr-carousel__stage">
        <div class="rr-carousel__viewport">
          <div class="rr-carousel__track">
            {merchSlides.map((slide) => (
              <div class="rr-carousel__slide">
                <a href={slide.href} target="_blank" rel="noopener noreferrer">
                  <Image src={slide.src} alt={slide.alt} loading="lazy" />
                </a>
              </div>
            ))}
          </div>
          <div class="rr-carousel__progress">
            <div class="rr-carousel__progress-bar">&nbsp;</div>
          </div>
        </div>

        <button class="rr-carousel__arrow rr-carousel__arrow--prev" type="button" aria-label="Previous" data-tooltip="Previous" data-tooltip-pos="above">&larr;</button>
        <button class="rr-carousel__arrow rr-carousel__arrow--next" type="button" aria-label="Next" data-tooltip="Next" data-tooltip-pos="above">&rarr;</button>
      </div>

      <div class="rr-carousel__dots">
        {merchSlides.map((_, i) => (
          <button class="rr-carousel__dot" type="button" aria-label={`Slide ${i + 1}`}></button>
        ))}
      </div>
    </div>
  </div>
</Layout>

<script src="../scripts/merch.js"></script>
