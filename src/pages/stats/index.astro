---
import Layout from '../../layouts/Layout.astro';
import '../../styles/divisions.css';
import '../../styles/livestats.css';

import { loadStatGroups } from '../../lib/stats';
import { DIVISIONS } from '../../site.config';

const columns = [
  { label: 'Player Name', type: 'string' },
  { label: 'Games', type: 'number' },
  { label: 'Wins', type: 'number' },
  { label: 'Win %', type: 'number' },
  { label: 'Avg Score', type: 'number' },
  { label: 'Avg Goals', type: 'number' },
  { label: 'Avg Assists', type: 'number' },
  { label: 'Avg Saves', type: 'number' },
  { label: 'Avg Speed', type: 'number' },
  { label: 'Avg % Supersonic', type: 'number' },
];

const { groups, seasonOptions, leagueOptions } = loadStatGroups();
const defaultSeason = seasonOptions[0];
const defaultLeague = leagueOptions[0];
---

<Layout
  title="Stats"
  description="Browse Rocket Rivals league statistics by division to track player progression, team performance, and seasonal trends."
>
  <div>
    <h2><strong>League Statistics&nbsp;</strong></h2>
    <p>Explore division-specific performance metrics from Rocket Rivals leagues<br />Find all-time team stats, league rankings, and title event histories </p>
  </div>

  <div class="rr-spacer rr-spacer--md"></div>

  <p>
    <label for="division-select">Select Division: </label>
    <select id="division-select" onchange="location = this.value;">
      <option value="#">-- None --</option>
      {DIVISIONS.map((division) => (
        <option value={`/stats/${division.id}`}>{division.label}</option>
      ))}
    </select>
  </p>
  <div class="rr-spacer rr-spacer--md"></div>

  <div class="rr-section-divider"></div>

  <div>
    <h2><strong>Live Stats&nbsp;</strong><span class="rr-livestats-badge" data-tooltip="This is a work-in-progress feature. Some data may be missing or inaccurate" data-tooltip-pos="above">Experimental</span></h2>
    <p class="rr-livestats-intro">
      Sortable league statistics pulled directly from our ballchasing records
    </p>
  </div>

  <div class="rr-livestats-filters">
    <label>
      Season:
      <select id="livestats-season-filter">
        {seasonOptions.map((season) => <option value={season}>{season}</option>)}
      </select>
    </label>
    <label>
      League:
      <select id="livestats-league-filter">
        {leagueOptions.map((league) => <option value={league}>{league}</option>)}
      </select>
    </label>
  </div>

  <div class="rr-livestats-search">
    <input
      type="search"
      id="livestats-search"
      placeholder="Search player name"
      aria-label="Search player name"
      autocomplete="off"
    />
  </div>

  <div class="rr-table-wrapper">
    {groups.map((group) => (
      <table
        class="rr-stats-table"
        data-season={group.season}
        data-league={group.league}
        data-visible={group.season === defaultSeason && group.league === defaultLeague ? 'true' : 'false'}
      >
        <thead>
          <tr>
            {columns.map((column, i) => (
              <th
                data-col={i}
                data-type={column.type}
                data-dir={column.label === 'Wins' ? 'desc' : undefined}
                class={column.label === 'Wins' ? 'is-sorted' : undefined}
              >{column.label}</th>
            ))}
          </tr>
        </thead>
        <tbody>
          {group.rows.map((row) => (
            <tr>
              {row.map((cell) => <td>{cell}</td>)}
            </tr>
          ))}
        </tbody>
      </table>
    ))}
  </div>
</Layout>
<div class="rr-spacer rr-spacer--md"></div>

<script src="../../scripts/livestats.js"></script>
