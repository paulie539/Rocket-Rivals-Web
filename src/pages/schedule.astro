---
import { Image } from 'astro:assets';
import Layout from '../layouts/Layout.astro';
import { DIVISIONS, SITE, type DivisionId } from '../site.config';

import '../styles/schedule.css';

import titansSchedule from '../assets/images/rocketrivalsszn8titansschedule.png';
import legendsSchedule from '../assets/images/rocketrivalsszn8legendsschedule.png';
import challengersSchedule from '../assets/images/rocketrivalsszn8challengersschedule.png';

// Static asset imports must be literal paths, so this map is the one place
// that still has to be updated by hand when a season's schedule images change.
const scheduleImages: Record<DivisionId, ImageMetadata> = {
  titans: titansSchedule,
  legends: legendsSchedule,
  challengers: challengersSchedule,
};

const twitchParent = new URL(SITE.url).hostname;
---

<Layout
  title="Schedule"
  description="Catch Rocket Rivals matches live on Twitch and check the Titans, Legends, and Challengers division match schedules for Saturday and Sunday nights."
>
  <div>
    <h2><strong>Come check out our live streams!</strong></h2>
  </div>

  <div class="rr-twitch-panel">
    <p><a href={SITE.twitchUrl}>{SITE.name} on Twitch</a></p>
    <div class="twitch-embed-wrapper">
      <iframe
        src={`https://player.twitch.tv/?channel=${SITE.twitchChannel}&parent=${twitchParent}&parent=localhost`}
        title={`${SITE.name} Twitch stream`}
        allowfullscreen
        loading="lazy"
      ></iframe>
    </div>
  </div>

  <h2>Twitch Schedule</h2>
  <div class="rr-schedule-wrapper">
    <p class="rr-schedule-intro">Matches are played on Saturday and Sunday evenings &mdash; all times Eastern.</p>
    <div class="rr-division-tabs">
      {DIVISIONS.map((division) => (
        <button type="button" class="rr-tab-btn" data-division={division.id}>{division.label}</button>
      ))}
    </div>
    <div class="rr-schedule-panels">
      {DIVISIONS.map((division) => (
        <div class="rr-schedule-panel" data-division={division.id}>
          <Image src={scheduleImages[division.id]} alt={`${division.label} Division Schedule`} width={750} height={420} loading="lazy" />
        </div>
      ))}
    </div>
  </div>
</Layout>

<script src="../scripts/schedule.js"></script>
